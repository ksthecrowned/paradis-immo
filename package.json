{
  "name": "paradis-immo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "install:api": "cd apps/api && bun install",
    "install:web": "cd apps/web && bun install",
    "install:mobile": "cd apps/mobile && bun install",
    "install:all": "bun run install:api && bun run install:web && bun run install:mobile",
    "build": "cd apps/api && bun run build && cd ../web && bun run build",
    "test": "cd apps/api && bun run test",
    "test:e2e": "cd apps/api && bun run test:e2e",
    "lint": "cd apps/web && bun run lint",
    "export:openapi": "cd apps/api && bun run export:openapi",
    "generate:types": "node scripts/generate-types.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
