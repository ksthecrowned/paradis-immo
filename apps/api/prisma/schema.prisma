// Prisma schema for Paradis Immo MVP
// Spec: docs/superpowers/specs/2026-06-27-paradis-immo-design.md (section 4)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================
// Enums
// =====================================================================

enum OrganizationType {
  PLATFORM
  AGENCY
  OWNER
}

enum AffiliationStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum OrgMemberRole {
  OWNER
  AGENT
  ADMIN
}

enum GlobalRole {
  TENANT
  BUYER
  PLATFORM_ADMIN
}

enum PropertyMode {
  RENT_SHORT
  RENT_LONG
  SALE
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PropertyType {
  APARTMENT
  HOUSE
  LAND
  COMMERCIAL
}

enum ListingStatus {
  AVAILABLE
  SOLD
  UNDER_OFFER
  OCCUPIED
  AVAILABLE_SOON
}

enum PropertyFeatureId {
  cuisine
  debarras
  climatisation
  chauffe_eau
  wifi
  piscine
  parking
  jardin
  securite
  groupe_electrogene
  meuble
  balcon
  terrasse
  eau_courante
}

enum MapViewId {
  neighborhood
  tour360
}

enum PriceUnit {
  NIGHT
  WEEK
  MONTH
  TOTAL
}

enum VisitType {
  FREE
  PAID
}

enum VisitSlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum VisitSlotSource {
  TEMPLATE
  MANUAL
}

enum VisitBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  TERMINATED
}

enum RentScheduleStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum SaleInquiryStatus {
  NEW
  CONTACTED
  VISIT_SCHEDULED
  CLOSED
}

enum MandateStatus {
  ACTIVE
  REVOKED
}

enum MandateActionType {
  LEASE_SIGN
  RENT_REDUCTION
  MAJOR_REPAIR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
}

enum PaymentProvider {
  AIRTEL
  MOMO
}

enum PaymentStatus {
  INITIATED
  PENDING_VALIDATION
  VALIDATED
  FAILED
  DISPUTED
}

enum AllocatableType {
  RENT_SCHEDULE
  BOOKING
  VISIT_BOOKING
  MESSAGING_DEBT
}

enum MessageChannel {
  WHATSAPP_OTP
  SMS_ALERT
}

enum MessagePayerType {
  USER
  ORGANIZATION
}

enum MessageChargeStatus {
  FREE
  OPEN
  SETTLED
  WAIVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  DONE
  CLOSED
}

enum NotificationChannel {
  PUSH
  WHATSAPP
  SMS
}

enum MagicLinkPurpose {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum SeekerIntent {
  RENT
  BUY
  VISIT
  ALL_OPTIONS
}

enum SeekerExperience {
  FIRST_TIME
  RETURNING
  PRO
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum MediaType {
  PHOTO
  VIDEO
}

enum DocumentType {
  TITLE_DEED
  PLAN
  OTHER
}

enum AvailabilityReason {
  BOOKING
  MAINTENANCE
  MANUAL
}

// =====================================================================
// Identity & Geography
// =====================================================================

model Country {
  id              String         @id @default(uuid())
  code            String         @unique
  name            String
  currency        String
  phonePrefix     String
  activeProviders String[]
  cities          City[]
  users           User[]
  organizations   Organization[]
  properties      Property[]
}

model User {
  id                     String               @id @default(uuid())
  phone                  String?
  email                  String?              @unique
  emailVerifiedAt        DateTime?
  /// scrypt hash `salt:hex` — web email/password login
  passwordHash           String?
  /// Google subject (`sub`) when linked for Google sign-in
  googleId               String?              @unique
  name                   String?
  avatarUrl              String?
  fcmToken               String?
  notificationChannel    NotificationChannel  @default(PUSH)
  seekerIntent           SeekerIntent?
  seekerExperience       SeekerExperience?
  budgetMinXaf           Int?
  budgetMaxXaf           Int?
  preferredQuartierIds   String[]             @default([])
  seekerSetupCompletedAt DateTime?
  countryId              String
  country                Country              @relation(fields: [countryId], references: [id])
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  orgMembers             OrganizationMember[]
  roles                  UserRole[]
  refreshTokens          RefreshToken[]
  favorites              Favorite[]
  visitBookings          VisitBooking[]
  bookings               Booking[]
  leases                 Lease[]              @relation("LeaseTenant")
  saleInquiries          SaleInquiry[]
  payments               Payment[]
  tickets                MaintenanceTicket[]  @relation("TicketReporter")
  assignedTickets        MaintenanceTicket[]  @relation("TicketAssignee")
  notifications          Notification[]
  messageCharges         MessageCharge[]      @relation("MessageChargeUser")
  assignedMandates       Mandate[]            @relation("MandateAssignedAgent")

  @@unique([phone, countryId])
}

model Organization {
  id                 String               @id @default(uuid())
  name               String
  type               OrganizationType
  affiliationStatus  AffiliationStatus?
  shortName          String?
  tagline            String?
  address            String?
  phone              String?
  cityLabel          String?
  logoColor          String?
  isOfficial         Boolean              @default(false)
  verified           Boolean              @default(false)
  foundedYear        Int?
  rating             Float?
  reviewCount        Int                  @default(0)
  dealSuccessPercent Int?
  countryId          String
  country            Country              @relation(fields: [countryId], references: [id])
  members            OrganizationMember[]
  properties         Property[]
  mandates           Mandate[]
  messageCharges     MessageCharge[]
  createdAt          DateTime             @default(now())
}

model OrganizationMember {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           OrgMemberRole
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model UserRole {
  id          String  @id @default(uuid())
  userId      String
  role        GlobalRole
  contextType String?
  contextId   String?
  user        User    @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model EmailMagicLink {
  id        String           @id @default(uuid())
  email     String
  tokenHash String           @unique
  purpose   MagicLinkPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([email, purpose])
}

// =====================================================================
// Locations
// =====================================================================

model City {
  id              String           @id @default(uuid())
  name            String
  countryId       String
  country         Country          @relation(fields: [countryId], references: [id])
  arrondissements Arrondissement[]

  @@unique([name, countryId])
}

model Arrondissement {
  id        String    @id @default(uuid())
  name      String
  number    Int?
  cityId    String
  city      City      @relation(fields: [cityId], references: [id])
  quartiers Quartier[]

  @@unique([name, cityId])
}

model Quartier {
  id               String         @id @default(uuid())
  name             String
  arrondissementId String
  arrondissement   Arrondissement @relation(fields: [arrondissementId], references: [id])
  properties       Property[]

  @@unique([name, arrondissementId])
}

// =====================================================================
// Properties
// =====================================================================

model Property {
  id             String              @id @default(uuid())
  ownerId        String
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  title          String
  description    String
  type           PropertyType
  mode           PropertyMode
  status         PropertyStatus      @default(DRAFT)
  price          Decimal             @db.Decimal(12, 2)
  currency       String
  priceUnit      PriceUnit
  quartierId     String
  quartier       Quartier            @relation(fields: [quartierId], references: [id])
  address        String
  lat            Float?
  lng            Float?
  countryId      String
  country        Country             @relation(fields: [countryId], references: [id])
  visitEnabled   Boolean             @default(false)
  visitType      VisitType?
  visitPrice     Decimal?            @db.Decimal(12, 2)
  visitDuration  Int?
  bedrooms       Int?
  bathrooms      Int?
  surface        Float?
  features            Json?
  listingStatus       ListingStatus @default(AVAILABLE)
  availableFrom       DateTime?
  isFeatured          Boolean       @default(false)
  floor               String?
  yearBuilt           Int?
  condition           String?
  lotSize             Float?
  parkingSpaces       Int?
  orientation         String?
  landTitle           String?
  mapViews            Json?
  media          PropertyMedia[]
  documents      PropertyDocument[]
  favorites      Favorite[]
  visitTemplates VisitSlotTemplate[]
  visitSlots     VisitSlot[]
  visitBookings  VisitBooking[]
  availability   AvailabilityBlock[]
  bookings       Booking[]
  leases         Lease[]
  saleInquiries  SaleInquiry[]
  mandates       Mandate[]
  maintenance    MaintenanceTicket[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model PropertyMedia {
  id         String    @id @default(uuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id])
  type       MediaType
  url        String
  position   Int       @default(0)
  createdAt  DateTime  @default(now())
}

model PropertyDocument {
  id         String       @id @default(uuid())
  propertyId String
  property   Property     @relation(fields: [propertyId], references: [id])
  type       DocumentType
  url        String
  name       String
  createdAt  DateTime     @default(now())
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
}

// =====================================================================
// Visits
// =====================================================================

model VisitSlotTemplate {
  id            String   @id @default(uuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id])
  dayOfWeek     Int // 0=Sunday .. 6=Saturday
  startTime     String // HH:mm
  endTime       String // HH:mm
  slotMinutes   Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model VisitSlot {
  id        String           @id @default(uuid())
  propertyId String
  property  Property         @relation(fields: [propertyId], references: [id])
  startAt   DateTime
  endAt     DateTime
  status    VisitSlotStatus  @default(AVAILABLE)
  source    VisitSlotSource  @default(TEMPLATE)
  booking   VisitBooking?
  createdAt DateTime         @default(now())

  @@unique([propertyId, startAt])
}

model VisitBooking {
  id          String            @id @default(uuid())
  slotId      String            @unique
  slot        VisitSlot         @relation(fields: [slotId], references: [id])
  propertyId  String
  property    Property          @relation(fields: [propertyId], references: [id])
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  status      VisitBookingStatus @default(PENDING)
  paymentId   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// =====================================================================
// Bookings (short-term)
// =====================================================================

model Booking {
  id         String        @id @default(uuid())
  propertyId String
  property   Property      @relation(fields: [propertyId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  startDate  DateTime
  endDate    DateTime
  totalPrice Decimal       @db.Decimal(12, 2)
  currency   String
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model AvailabilityBlock {
  id         String            @id @default(uuid())
  propertyId String
  property   Property          @relation(fields: [propertyId], references: [id])
  startDate  DateTime
  endDate    DateTime
  reason     AvailabilityReason
  refId      String?
  createdAt  DateTime          @default(now())
}

// =====================================================================
// Leases & Rent
// =====================================================================

model Lease {
  id             String         @id @default(uuid())
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id])
  tenantId       String
  tenant         User           @relation("LeaseTenant", fields: [tenantId], references: [id])
  startDate      DateTime
  endDate        DateTime
  monthlyRent    Decimal        @db.Decimal(12, 2)
  currency       String
  deposit        Decimal        @db.Decimal(12, 2)
  status         LeaseStatus    @default(DRAFT)
  mandateId      String?
  mandate        Mandate?       @relation(fields: [mandateId], references: [id])
  schedule       RentSchedule[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RentSchedule {
  id        String            @id @default(uuid())
  leaseId   String
  lease     Lease             @relation(fields: [leaseId], references: [id])
  dueDate   DateTime
  amount    Decimal           @db.Decimal(12, 2)
  currency  String
  status    RentScheduleStatus @default(PENDING)
  payments  PaymentAllocation[]
  createdAt DateTime          @default(now())

  @@unique([leaseId, dueDate])
}

// =====================================================================
// Sales
// =====================================================================

model SaleInquiry {
  id         String            @id @default(uuid())
  propertyId String
  property   Property          @relation(fields: [propertyId], references: [id])
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  message    String?
  status     SaleInquiryStatus @default(NEW)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

// =====================================================================
// Mandates
// =====================================================================

model Mandate {
  id               String              @id @default(uuid())
  propertyId       String
  property         Property            @relation(fields: [propertyId], references: [id])
  organizationId   String
  organization     Organization        @relation(fields: [organizationId], references: [id])
  /// Field agent (or gérant) responsible inside the agency — null = gérant-only ops
  assignedAgentId  String?
  assignedAgent    User?               @relation("MandateAssignedAgent", fields: [assignedAgentId], references: [id])
  status           MandateStatus       @default(ACTIVE)
  startDate        DateTime            @default(now())
  endDate          DateTime?
  leases           Lease[]
  approvals        MandateApproval[]
  createdAt        DateTime            @default(now())
}

model MandateApproval {
  id        String            @id @default(uuid())
  mandateId String
  mandate   Mandate           @relation(fields: [mandateId], references: [id])
  actionType MandateActionType
  payload    Json
  status    ApprovalStatus    @default(PENDING)
  decidedAt DateTime?
  decidedBy String?
  createdAt DateTime          @default(now())
}

// =====================================================================
// Payments
// =====================================================================

model Payment {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  amount          Decimal             @db.Decimal(12, 2)
  currency        String
  method          PaymentMethod
  provider        PaymentProvider?
  status          PaymentStatus       @default(INITIATED)
  reference       String              @unique
  idempotencyKey  String              @unique
  validatedBy     String?
  validatedAt     DateTime?
  metadata        Json?
  allocations     PaymentAllocation[]
  receipt         Receipt?
  messageCharges  MessageCharge[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model PaymentAllocation {
  id             String          @id @default(uuid())
  paymentId      String
  payment        Payment         @relation(fields: [paymentId], references: [id])
  type           AllocatableType
  refId          String
  amount         Decimal         @db.Decimal(12, 2)
  rentScheduleId String?
  rentSchedule   RentSchedule?   @relation(fields: [rentScheduleId], references: [id])
  createdAt      DateTime        @default(now())
}

model Receipt {
  id        String   @id @default(uuid())
  paymentId String   @unique
  payment   Payment  @relation(fields: [paymentId], references: [id])
  url       String
  number    String   @unique
  createdAt DateTime @default(now())
}

model MessageCharge {
  id                String              @id @default(uuid())
  channel           MessageChannel
  payerType         MessagePayerType
  payerId           String
  userId            String?
  user              User?               @relation("MessageChargeUser", fields: [userId], references: [id])
  organizationId    String?
  organization      Organization?       @relation(fields: [organizationId], references: [id])
  recipientPhone    String
  occurredAt        DateTime            @default(now())
  billingMonth      String
  unitUsd           Decimal             @db.Decimal(12, 6)
  fxRate            Decimal             @db.Decimal(12, 4)
  amountXaf         Int
  status            MessageChargeStatus
  settledPaymentId  String?
  settledPayment    Payment?            @relation(fields: [settledPaymentId], references: [id])
  providerMessageId String?
  idempotencyKey    String              @unique
  createdAt         DateTime            @default(now())

  @@index([payerType, payerId, status])
  @@index([userId, channel, billingMonth])
  @@index([billingMonth])
}

// =====================================================================
// Maintenance
// =====================================================================

model MaintenanceTicket {
  id                   String              @id @default(uuid())
  propertyId           String
  property             Property            @relation(fields: [propertyId], references: [id])
  reporterId           String
  reporter             User                @relation("TicketReporter", fields: [reporterId], references: [id])
  assigneeId           String?
  assignee             User?               @relation("TicketAssignee", fields: [assigneeId], references: [id])
  title                String
  description          String
  priority             MaintenancePriority @default(MEDIUM)
  status               MaintenanceStatus   @default(OPEN)
  estimatedCost        Decimal?            @db.Decimal(12, 2)
  requiresOwnerApproval Boolean            @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

// =====================================================================
// Notifications
// =====================================================================

model Notification {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  channel   NotificationChannel
  type      String
  payload   Json
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime            @default(now())
}

// =====================================================================
// Auth — OTP challenges (replaces Redis for MVP)
// =====================================================================

model OtpChallenge {
  phone              String   @id
  code               String
  /// LOGIN = existing user only; REGISTER = create if missing
  purpose            String   @default("REGISTER")
  attempts           Int      @default(0)
  expiresAt          DateTime
  requestCount       Int      @default(1)
  requestWindowEndAt DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
