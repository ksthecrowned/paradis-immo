# Paradis Immo API — required env vars
DATABASE_URL=postgresql://postgres:postpass@localhost:5432/paradis_immo

# Auth
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# CORS (production only)
ALLOWED_ORIGINS=https://app.paradisimmo.cg

# R2 media (optional in dev — API throws if presign is called without it)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=paradis-immo
R2_PUBLIC_URL=

# Infobip WhatsApp / SMS (optional in dev — OTP is logged to console)
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
INFOBIP_WHATSAPP_SENDER=
INFOBIP_SMS_SENDER=

# Messaging billing (XAF via fixed FX)
USD_TO_XAF=600
OTP_FREE_PER_MONTH=10
OTP_UNIT_USD=0.006
SMS_ALERT_UNIT_USD=0.234

# Mobile Money
MOBILE_MONEY_PROVIDER=AIRTEL
MOBILE_MONEY_API_KEY=
MOBILE_MONEY_WEBHOOK_SECRET=

# FCM push — path to Firebase service-account JSON, or raw JSON string
# Example: FCM_CREDENTIALS=./secrets/firebase-service-account.json
FCM_CREDENTIALS=
